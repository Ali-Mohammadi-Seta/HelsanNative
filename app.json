{
  "expo": {
    "name": "سلام",
    "slug": "helsan-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "salam",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salam.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Salam uses the camera for video consultations.",
        "NSMicrophoneUsageDescription": "Salam uses the microphone for voice and video consultations.",
        "NSLocationWhenInUseUsageDescription": "Salam uses your location to improve nearby healthcare services."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.salam.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-localization",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://192.168.31.169:8080/api",
      "behdashtCallbackUrl": "salam://health-ministry-callback",
      "consultationSsoUrl": "https://sso.inhso.ir/oidc/auth?client_id=client_1754117598828_b4e0885381f0f549&redirect_uri=https://consultation.inhso.ir/LoginFromSso&response_type=code&state=random-string&scope=openid%20profile%20email%20offline_access&resource=https://inhso.ir",
      "sepehrSalamatSsoUrl": "https://sso.inhso.ir/oidc/auth?client_id=client_1753181661291_29ef29cc769b9291&redirect_uri=https://inhs.isikato.ir/LoginFromSso&response_type=code&state=random-string&scope=openid%20profile%20email%20offline_access&resource=https://inhso.ir",
      "ssoLogoutUrl": "https://sso.inhso.ir/auth/logout",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "81d67089-9133-4446-8dca-9877b70f4488"
      }
    }
  }
}
